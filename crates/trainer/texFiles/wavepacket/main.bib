@Article{	  ha1980,
  annote	= {We consider the $\hbar\to0$ limit of the quantum dynamics
		  generated by the Hamiltonian
		  $H(\hbar)=-(\hbar^2/2m)\Delta+V$. We prove that the
		  evolution of certain Gaussian states is determined
		  asymptotically as $\hbar\to0$ by classical mechanics. For
		  suitable potentials $V$ in $n\ge3$ dimensions, our
		  estimates are uniform in time and our results hold for
		  scattering theory.},
