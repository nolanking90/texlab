\newcommand{\makeheading}[1]
{%
    \begin{center}
        \begin{minipage}[t]{\textwidth-30pt}
	    {\begin{center}\large \bfseries  #1 \end{center}}%
	    \rule{\columnwidth}{1pt}%
        \end{minipage}%
    \end{center}%
}

