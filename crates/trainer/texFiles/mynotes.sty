% tcolorbox environments, settings, and colors
\usepackage[many]{tcolorbox} 
\definecolor{main}{HTML}{5989cf}    
\definecolor{sub}{HTML}{cde4ff}     
\definecolor{probTitle}{HTML}{023e8a}
\definecolor{thmTitle}{HTML}{03543f}
\definecolor{defTitle}{HTML}{8f2d56}
\definecolor{corTitle}{HTML}{cf9b30}
%82a3a1 morning blue
%F75590 violet red
%D0CCD0 light grey
%1B9AAA blue munsell

\tcbset{
    colframe = black,
    colback = probTitle!20!white,
    colbacktitle = probTitle,
    coltitle = white,
    fonttitle = \bfseries,
    before skip = 0.5cm,    
    after skip = .7cm,      
    boxrule = 2pt,
}%

\newcounter{thmCnt}[section]
\tcbmaketheorem{thmbox}{Theorem}%
{colback=thmTitle!20!white, colbacktitle=thmTitle}{thmCnt}{thm}

\newcounter{stratCnt}[section]
\tcbmaketheorem{stratbox}{Strategy}%
{colback=thmTitle!20!white, colbacktitle=thmTitle}{stratCnt}{strt}

\tcbmaketheorem{defnbox}{Definition}%
{colback=defTitle!20!white, colbacktitle=defTitle}{thmCnt}{defn}

\tcbmaketheorem{cor}{Corollary}%
{colback=corTitle!20!white, colbacktitle=corTitle}{thmCnt}{cor}

\newcounter{exer}[section]
\newenvironment{exer}%
{%
    \refstepcounter{exer}%
    \begin{tcolorbox}[title = Problem ~\theexer]%
}{\medskip\end{tcolorbox}} 

\newcounter{discuss}[section]
\newenvironment{discuss}%
{%
